---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <!-- ブランド -->
      <div class="footer-brand">
        <a href="/" class="footer-logo">
          <span class="footer-logo-icon" aria-hidden="true">◆</span>
          <span class="footer-logo-text">FigBlog</span>
        </a>
        <p class="footer-tagline">フィギュア情報をもっと身近に。</p>
        <p class="footer-desc">
          一番くじ・プライズ・新作フィギュアの<br />
          最新情報とレビューをお届けします。
        </p>
      </div>

      <!-- カテゴリ -->
      <div class="footer-col">
        <h3 class="footer-heading">カテゴリ</h3>
        <ul class="footer-links">
          <li><a href="/category/ichiban-kuji">一番くじ</a></li>
          <li><a href="/category/prize">プライズ</a></li>
          <li><a href="/category/new-arrival">新作フィギュア</a></li>
        </ul>
      </div>

      <!-- コンテンツ -->
      <div class="footer-col">
        <h3 class="footer-heading">コンテンツ</h3>
        <ul class="footer-links">
          <li><a href="/blog">記事一覧</a></li>
          <li><a href="/ranking">ランキング</a></li>
          <li><a href="/feature">おすすめ</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p class="footer-affiliate-notice">
        ※ 本サイトのリンクにはアフィリエイトが含まれます。
      </p>
      <p class="footer-copy">
        &copy; {year} FigBlog. All rights reserved.
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: #f8f7f5;
    border-top: 1px solid #e5e2dc;
    padding: 3rem 0 1.5rem;
    margin-top: 5rem;
  }

  .container {
    width: 100%;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  @media (min-width: 640px) {
    .container {
      padding: 0 1.5rem;
    }
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-bottom: 2.5rem;
  }

  @media (min-width: 640px) {
    .footer-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .footer-grid {
      grid-template-columns: 2fr 1fr 1fr;
    }
  }

  /* ブランド */
  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    margin-bottom: 0.75rem;
  }

  .footer-logo-icon {
    font-size: 1rem;
    color: #c8380a;
  }

  .footer-logo-text {
    font-family: 'Outfit', 'Noto Sans JP', sans-serif;
    font-size: 1.0625rem;
    font-weight: 700;
    color: #1c1a18;
    letter-spacing: -0.01em;
  }

  .footer-tagline {
    font-size: 0.875rem;
    font-weight: 500;
    color: #1c1a18;
    margin: 0 0 0.5rem;
  }

  .footer-desc {
    font-size: 0.8125rem;
    color: #a09890;
    line-height: 1.6;
    margin: 0;
  }

  /* カラム */
  .footer-heading {
    font-family: 'Outfit', 'Noto Sans JP', sans-serif;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #a09890;
    margin: 0 0 0.875rem;
  }

  .footer-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .footer-links a {
    font-size: 0.875rem;
    color: #6b6560;
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .footer-links a:hover {
    color: #1c1a18;
  }

  /* ボトム */
  .footer-bottom {
    border-top: 1px solid #e5e2dc;
    padding-top: 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.375rem;
    text-align: center;
  }

  .footer-affiliate-notice {
    font-size: 0.75rem;
    color: #a09890;
    margin: 0;
  }

  .footer-copy {
    font-size: 0.75rem;
    color: #ccc9c3;
    margin: 0;
  }
</style>
