---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_TITLE } from '../consts';
import { getBlogPosts, resolveDate } from '../lib/microcms';

const { contents: posts } = await getBlogPosts({
  filters: 'featured[equals]true',
  orders: '-publishDate,-publishedAt',
  limit: 20,
});

function formatDate(date: Date) {
  return date.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<BaseLayout title={`おすすめ特集 | ${SITE_TITLE}`} description="FigBlog編集部が厳選したおすすめフィギュア記事の特集です。" withSidebar={true}>
  <div class="feature-page">
    <div class="page-header">
      <h1 class="page-title">おすすめ特集</h1>
      <p class="page-desc">編集部が厳選したフィギュア記事をお届けします。</p>
    </div>

    {posts.length > 0 ? (
      <div class="posts-grid">
        {posts.map((post) => {
          const date = resolveDate(post);
          return (
            <article class="post-card">
              <a href={`/blog/${post.id}/`} class="post-card-link">
                <div class="post-card-image">
                  {post.heroImage ? (
                    <img src={post.heroImage.url} alt={post.title} loading="lazy" width="600" height="400" />
                  ) : (
                    <div class="post-card-placeholder" aria-hidden="true"><span>⭐</span></div>
                  )}
                </div>
                <div class="post-card-body">
                  <span class="featured-badge">おすすめ</span>
                  <h2 class="post-card-title">{post.title}</h2>
                  <p class="post-card-desc">{post.description}</p>
                  <time class="post-card-date" datetime={date.toISOString()}>{formatDate(date)}</time>
                </div>
              </a>
            </article>
          );
        })}
      </div>
    ) : (
      <p class="empty-message">特集記事を準備中です。しばらくお待ちください。</p>
    )}
  </div>
</BaseLayout>

<style>
  .page-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid #e5e2dc;
  }

  .page-title {
    font-family: 'Outfit', 'Noto Sans JP', sans-serif;
    font-size: clamp(1.625rem, 4vw, 2rem);
    font-weight: 700;
    color: #1c1a18;
    margin: 0 0 0.375rem;
    padding-left: 0.875rem;
    border-left: 3px solid #c8380a;
    letter-spacing: -0.015em;
  }

  .page-desc {
    font-size: 0.875rem;
    color: #6b6560;
    margin: 0.5rem 0 0 1.125rem;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  @media (min-width: 640px) {
    .posts-grid { grid-template-columns: repeat(2, 1fr); }
  }

  .post-card {
    background: #ffffff;
    border: 1px solid #e5e2dc;
    border-radius: 8px;
    overflow: hidden;
    transition: box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .post-card:hover {
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    border-color: #ccc9c3;
  }

  .post-card-link { display: block; text-decoration: none; }

  .post-card-image {
    aspect-ratio: 16/9;
    overflow: hidden;
    background: #f0ede9;
  }

  .post-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.35s ease;
  }

  .post-card:hover .post-card-image img { transform: scale(1.03); }

  .post-card-placeholder {
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
    font-size: 2.5rem; opacity: 0.2;
  }

  .post-card-body { padding: 1rem; }

  .featured-badge {
    display: inline-block;
    font-size: 0.625rem;
    font-weight: 700;
    color: #c8380a;
    background: rgba(200, 56, 10, 0.07);
    border: 1px solid rgba(200, 56, 10, 0.2);
    padding: 0.15rem 0.5rem;
    border-radius: 3px;
    margin-bottom: 0.625rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .post-card-title {
    font-family: 'Outfit', 'Noto Sans JP', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    color: #1c1a18;
    line-height: 1.45;
    margin: 0 0 0.5rem;
    letter-spacing: -0.01em;
  }

  .post-card-desc {
    font-size: 0.8125rem;
    color: #6b6560;
    line-height: 1.6;
    margin: 0 0 0.625rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-card-date { font-size: 0.75rem; color: #a09890; }

  .empty-message {
    color: #a09890;
    text-align: center;
    padding: 4rem 0;
    font-size: 0.9375rem;
  }
</style>
