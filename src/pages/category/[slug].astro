---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { CATEGORIES, CATEGORY_LABELS, CATEGORY_DESCRIPTIONS } from '../../consts';
import { getBlogPosts, resolveDate, resolveTags } from '../../lib/microcms';

export async function getStaticPaths() {
  return CATEGORIES.map((cat) => ({ params: { slug: cat.key } }));
}

const { slug } = Astro.params;
const label = CATEGORY_LABELS[slug] ?? slug;
const description = CATEGORY_DESCRIPTIONS[slug] ?? `${label}に関する記事一覧。`;

const { contents: posts } = await getBlogPosts({
  filters: `category[equals]${slug}`,
  orders: '-publishDate,-publishedAt',
  limit: 50,
});

function formatDate(date: Date) {
  return date.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<BaseLayout title={`${label} | FigBlog`} description={description} withSidebar={true}>
  <div class="category-page">
    <div class="page-header">
      <p class="page-breadcrumb"><a href="/">TOP</a> › カテゴリ</p>
      <h1 class="page-title">{label}</h1>
      <p class="page-desc">{description}</p>
    </div>

    {posts.length > 0 ? (
      <>
        <p class="post-count">{posts.length}件の記事</p>
        <div class="posts-grid">
          {posts.map((post) => {
            const date = resolveDate(post);
            const tags = resolveTags(post.tags);
            return (
              <article class="post-card">
                <a href={`/blog/${post.id}/`} class="post-card-link">
                  <div class="post-card-image">
                    {post.heroImage ? (
                      <img src={post.heroImage.url} alt={post.title} loading="lazy" width="360" height="270" />
                    ) : (
                      <div class="post-card-placeholder" aria-hidden="true"><span>📦</span></div>
                    )}
                  </div>
                  <div class="post-card-body">
                    <h2 class="post-card-title">{post.title}</h2>
                    <p class="post-card-desc">{post.description}</p>
                    {tags.length > 0 && (
                      <div class="post-card-tags">
                        {tags.slice(0, 3).map((tag) => <span class="tag">#{tag}</span>)}
                      </div>
                    )}
                    <time class="post-card-date" datetime={date.toISOString()}>{formatDate(date)}</time>
                  </div>
                </a>
              </article>
            );
          })}
        </div>
      </>
    ) : (
      <p class="empty-message">このカテゴリの記事はまだありません。</p>
    )}
  </div>
</BaseLayout>

<style>
  .page-header {
    margin-bottom: 1.75rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  .page-breadcrumb {
    font-size: 0.75rem;
    color: var(--text-3);
    margin: 0 0 0.5rem;
  }

  .page-breadcrumb a {
    color: var(--text-3);
    text-decoration: none;
  }

  .page-breadcrumb a:hover { color: var(--accent); }

  .page-title {
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 700;
    color: var(--text);
    margin: 0 0 0.375rem;
    padding-left: 0.875rem;
    border-left: 3px solid var(--accent);
    letter-spacing: -0.015em;
  }

  .page-desc {
    font-size: 0.875rem;
    color: var(--text-2);
    margin: 0.5rem 0 0 1.125rem;
  }

  .post-count {
    font-size: 0.8125rem;
    color: var(--text-3);
    margin: 0 0 1rem;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media (min-width: 640px) { .posts-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .posts-grid { grid-template-columns: repeat(2, 1fr); } }

  .post-card {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    transition: box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .post-card:hover {
    box-shadow: 0 4px 20px rgba(0,0,0,0.08);
    border-color: var(--border-strong);
  }

  .post-card-link { display: block; text-decoration: none; }

  .post-card-image {
    position: relative;
    aspect-ratio: 16/10;
    overflow: hidden;
    background: var(--bg-muted);
  }

  .post-card-image img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.35s ease; }
  .post-card:hover .post-card-image img { transform: scale(1.03); }

  .post-card-placeholder {
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
    font-size: 2.5rem; opacity: 0.2;
  }

  .post-card-body { padding: 0.875rem 1rem 1rem; }

  .post-card-title {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--text);
    line-height: 1.45;
    margin: 0 0 0.4375rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    letter-spacing: -0.01em;
  }

  .post-card-desc {
    font-size: 0.8125rem;
    color: var(--text-2);
    line-height: 1.6;
    margin: 0 0 0.5rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-card-tags { display: flex; flex-wrap: wrap; gap: 0.3rem; margin-bottom: 0.5rem; }

  .tag {
    font-size: 0.6875rem;
    color: var(--text-3);
    background: var(--bg-muted);
    padding: 0.15rem 0.45rem;
    border-radius: 3px;
  }

  .post-card-date { font-size: 0.75rem; color: var(--text-3); }

  .empty-message {
    color: var(--text-3);
    text-align: center;
    padding: 4rem 0;
    font-size: 0.9375rem;
  }
</style>
